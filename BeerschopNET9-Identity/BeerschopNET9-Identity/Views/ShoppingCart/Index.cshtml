@using BeerschopNET9_Identity.ViewModels
@model ShoppingCartVM

@{
    ViewData["Title"] = "Shopping Cart";

    var carts = Model?.Carts ?? new List<CartVM>();
    var grandTotal = carts.Sum(x => x.Price * x.Count);
}

<h2>Shopping Cart</h2>

@if (!carts.Any())
{
    <div class="alert alert-info">
        Je shopping cart is leeg
    </div>
}
else
{
    <table class="table table-striped">

        <thead>
            <tr>
                <th>Product</th>
                <th class="text-end">Prijs</th>
                <th class="text-center">Aantal</th>
                <th class="text-end">Totaal</th>
                <th class="text-end">Acties</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in carts)
            {
                var lineTotal = item.Price * item.Count;

                <tr>

                    <td>@item.Name</td>

                    <td class="text-end">@item.Price.ToString("0.00")</td>

                    <td class="text-center">

                        <form asp-controller="ShoppingCart" asp-action="Update" method="post" class="d-flex justify-content-center gap-2">

                            <input type="hidden" name="beerNumber" value="@item.BeerNumber" />

                            <input type="number"
                                   name="count"
                                   value="@item.Count"
                                   min="0"
                                   class="form-control"
                                   style="width:80px;" />

                            <button type="submit" class="btn btn-primary btn-sm">
                                Update
                            </button>

                        </form>

                    </td>

                    <td class="text-end">
                        @lineTotal.ToString("0.00")
                    </td>

                    <td class="text-end">

                        <a asp-controller="ShoppingCart"
                           asp-action="Remove"
                           asp-route-id="@item.BeerNumber"
                           class="btn btn-danger btn-sm">
                            Remove
                        </a>

                    </td>

                </tr>
            }

        </tbody>

        <tfoot>

            <tr>
                <td colspan="3" class="text-end fw-bold">
                    Totaal
                </td>

                <td class="text-end fw-bold">
                    @grandTotal.ToString("0.00")
                </td>

                <td></td>
            </tr>

        </tfoot>

    </table>

    <div class="d-flex justify-content-between mt-4">

        <a asp-controller="Beer"
           asp-action="Index"
           class="btn btn-outline-secondary">
            ← Verder winkelen
        </a>

        <a asp-controller="ShoppingCart"
           asp-action="Payment"
           class="btn btn-success">
            Naar checkout →
        </a>

    </div>

    <a asp-controller="ShoppingCart"
       asp-action="Clear"
       class="btn btn-warning">
        Cart leegmaken
    </a>
}