@model vancoillie_batiste.ViewModels.CreateLiedjeVM

@{
    ViewData["Title"] = "Create";
}

TempData["ErrorMessage"]

<h1>Liedjes</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Artiest" class="control-label"></label>
                <input asp-for="Artiest" class="form-control" />
                <span asp-validation-for="Artiest" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <label asp-for="Titel" class="control-label"></label>
                <input asp-for="Titel" class="form-control" />
                <span asp-validation-for="Titel" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="GenreNr" class="control-label"></label>

                <select asp-for="GenreNr" class="form-control"
                        asp-items="@Model.Genres">
                    <option>Please select one</option>
                </select>

                <span asp-validation-for="Genres" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
            
        </form>
    </div>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
