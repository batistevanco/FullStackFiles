@model IEnumerable<BeerShopTest.ViewModels.BeerVM>

<h2>Beers</h2>

<table id="beerTable" class="display">
    <thead>
        <tr>
            <th>Name</th>
            <th>Alcohol %</th>
            <th>Brewery</th>
            <th>Variety</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var b in Model)
        {
            <tr>
                <td>@b.Naam</td>
                <td>@b.Alcohol</td>
                <td>@b.BreweryName</td>
                <td>@b.VarietyName</td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#beerTable').DataTable({
                ordering: true, 
                paging: true,
                searching: true
            });
        });
    </script>
}